{
  "name": "voxail",
  "version": "1.0.0",
  "description": "AI-powered audio transcription using Gemini",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n whisper,server,web -c magenta,cyan,green \"npm:dev:whisper\" \"npm:dev:server\" \"npm:dev:frontend\"",
    "dev:frontend": "vite",
    "dev:server": "nodemon server/index.js",
    "dev:whisper": "bash services/whisper/run.sh",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "test": "node --test server/*.test.js",
    "test:whisper": "services/whisper/.venv/bin/python -m pytest services/whisper/tests -q",
    "test:all": "npm test && npm run test:whisper",
    "eval:whisper": "services/whisper/.venv/bin/python -m services.whisper.evals.eval_transcription"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "lucide-react": "^0.576.0",
    "multer": "^1.4.5-lts.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1"
  }
}
