# ═══ semaje configuration ════════════════════════════════════
# Deployment mode is adapter-driven: the same codebase runs
# single-user self-host, small-team self-host, and cloud.

# ── Database (Postgres) ──────────────────────────────────────
DATABASE_URL=postgres://semaje:semaje@localhost:5432/semaje

# ── Auth adapter ─────────────────────────────────────────────
# single-user → no login at all (default; seeds one org/user)
# local-db    → email+password accounts (small team)
AUTH_ADAPTER=single-user
JWT_SECRET=change-me-in-production
# Frontend mirror of the auth mode (hides/shows login screens)
VITE_AUTH_MODE=single-user

# ── Storage adapter (audio blobs) ────────────────────────────
# fs → local disk (default) | s3 → MinIO/S3/GCS
STORAGE_ADAPTER=fs
STORAGE_FS_DIR=./data/blobs
# s3 settings (MinIO example)
#S3_ENDPOINT=http://localhost:9000
#S3_BUCKET=semaje
#S3_ACCESS_KEY=semaje
#S3_SECRET_KEY=semaje-secret

# ── LLM adapter (the 15 language tasks) ──────────────────────
# ollama       → local Ollama HTTP server (self-host default)
# claude-local → local Claude Code CLI
# gemini       → Gemini HTTP API (optional; needs GEMINI_API_KEY)
LLM_ADAPTER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
LLAMA_CPP_URL=http://localhost:8081
LLAMA_CPP_MODEL=local-model
LLAMA_CPP_MODEL_FILE=model.gguf
LLM_FALLBACKS=llama-cpp,claude-local
EMBEDDING_ENABLED=false
EMBEDDING_MODEL=nomic-embed-text
GEMINI_API_KEY=
#CLAUDE_BIN=claude

# ── Whisper STT (transcription engine) ───────────────────────
WHISPER_URL=http://localhost:8011
WHISPER_BACKEND=faster-whisper
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WORKER_CONCURRENCY=1
MAX_QUEUED_JOBS=100
WHISPER_MODEL_DIR=./data/models

# ── API ──────────────────────────────────────────────────────
PORT=3001
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
UPLOAD_MAX_MB=500
RATE_LIMIT_POINTS=120
WEBHOOK_SECRET=change-me-webhooks
STRICT_LOCAL_MODE=true

# ── Cloud identity (Phase 3 OIDC adapter seam) ───────────────
#AUTH_ADAPTER=oidc
#OIDC_ISSUER=https://issuer.example
#OIDC_CLIENT_ID=
#OIDC_CLIENT_SECRET=
#OIDC_REDIRECT_URI=http://localhost:3001/api/auth/oidc/callback

# ── Billing / metering (Phase 4 Stripe seam) ─────────────────
BILLING_ADAPTER=disabled
STRIPE_WEBHOOK_SECRET=
PLAN_MINUTES=1000
PLAN_STORAGE_GB=50

# ── Meeting bot (Phase 4 seam) ───────────────────────────────
MEETING_BOT_ENABLED=false
CALENDAR_OAUTH_CLIENT_ID=
CALENDAR_OAUTH_CLIENT_SECRET=

# ── Frontend ─────────────────────────────────────────────────
# "proxy"  → server-side keys (recommended) | "direct" → BYO Gemini key in UI
VITE_API_MODE=proxy
