# ── Backend Proxy Mode ───────────────────────────────────────
# Your Gemini API key (get a free one at aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Port for the Express backend (default: 3001)
PORT=3001

# ── Frontend ─────────────────────────────────────────────────
# "proxy"  → use your backend server (key stays secret)
# "direct" → users enter their own API key in the UI
VITE_API_MODE=proxy
