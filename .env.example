# ── Backend Proxy Mode ───────────────────────────────────────
# Your Anthropic API key (get one at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Port for the Express backend (default: 3001)
PORT=3001

# ── Frontend ─────────────────────────────────────────────────
# "proxy"  → use your backend server (key stays secret)
# "direct" → users enter their own API key in the UI
VITE_API_MODE=proxy
