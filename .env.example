# ── Whisper STT (transcription engine) ───────────────────────
# Voxail transcribes with Whisper locally. The Node server talks to the
# Whisper service (services/whisper) over HTTP.
WHISPER_URL=http://localhost:8011

# Which backend the Whisper service runs (set in services/whisper, shown here
# for reference): "faster-whisper" (default) or "whisper.cpp".
WHISPER_BACKEND=faster-whisper
# Model: tiny | base | small | medium | large-v3  (base = fast + accurate)
WHISPER_MODEL=base

# ── Gemini (task post-processing only) ───────────────────────
# Used ONLY for the language tasks (summary, sentiment, chapters, translation,
# diarization, meeting/medical/legal formatting, etc.) that run over the
# Whisper transcript. Plain transcription never calls Gemini.
# Get a free key at aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Port for the Express backend (default: 3001)
PORT=3001

# ── Frontend ─────────────────────────────────────────────────
# "proxy"  → use your backend server (Gemini key stays secret)
# "direct" → users enter their own Gemini key in the UI (tasks only)
VITE_API_MODE=proxy
