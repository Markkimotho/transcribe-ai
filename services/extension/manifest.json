{
  "manifest_version": 3,
  "name": "semaje — dictate & transcribe anywhere",
  "version": "1.0.0",
  "description": "Voice dictation into any text box, plus your semaje transcript library in a side panel.",
  "permissions": ["storage", "offscreen", "sidePanel", "activeTab", "scripting"],
  "host_permissions": ["http://localhost/*", "http://localhost:3001/*", "https://*/*"],
  "background": { "service_worker": "src/background/service-worker.js", "type": "module" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/cursor-insert.js", "src/content/dictation-widget.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": { "default_path": "src/sidepanel/panel.html" },
  "action": {
    "default_title": "semaje",
    "default_popup": "src/popup/popup.html"
  },
  "commands": {
    "toggle-dictation": {
      "suggested_key": { "default": "Ctrl+Shift+1", "mac": "Command+Shift+1" },
      "description": "Start/stop dictation into the focused text box"
    }
  }
}
